modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run lint"

[workflows.workflow.metadata]
isValidation = true

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["node", "server.js"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
COMMISSION_RATE = "0.02"
MARKET_CACHE_TTL_HOURS = "6"

[userenv.development]
NODE_ENV = "development"
PORT = "5000"

[userenv.production]
NODE_ENV = "production"
PORT = "5000"
ALLOWED_ORIGINS = "https://sgs-land.replit.app"
# JWT_SECRET must be set via Replit Secrets (not here) — see replit.md for setup instructions
