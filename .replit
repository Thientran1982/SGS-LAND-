modules = ["nodejs-20", "web", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 24678
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["node", "server.js"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
COMMISSION_RATE = "0.02"
MARKET_CACHE_TTL_HOURS = "6"
JWT_SECRET = "a98097345cb9e55e6af1d2e3e52e4d493d32fefb81a2c351807ad6c5d23d7d488236160c58835c70c7e8758d6d24f1c09dc2270b70807801e2d2966e51dfa411"

[userenv.development]
NODE_ENV = "development"

[userenv.production]
NODE_ENV = "production"
PORT = "5000"
# JWT_SECRET must be set via Replit Secrets (not here) — see replit.md for setup instructions
