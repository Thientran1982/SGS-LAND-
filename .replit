modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3002

[[ports]]
localPort = 24678
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["node", "server.js"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
COMMISSION_RATE = "0.02"
MARKET_CACHE_TTL_HOURS = "6"

[userenv.development]
NODE_ENV = "development"

[userenv.production]
NODE_ENV = "production"
PORT = "5000"
ALLOWED_ORIGINS = "https://*.replit.app,https://*.replit.dev"
# JWT_SECRET must be set via Replit Secrets (not here) — see replit.md for setup instructions
