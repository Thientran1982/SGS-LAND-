# ============================================================
# SGS LAND — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# --- Database (Required) ---
DATABASE_URL=postgresql://user:password@localhost:5432/sgsland

# --- AI (Required for AI features) ---
GEMINI_API_KEY=

# --- Auth (Required in production) ---
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars

# --- Seed (Required when running npm run seed) ---
# Must be a strong password — used for all demo/dev users
SEED_PASSWORD=

# --- App ---
NODE_ENV=development
PORT=5000
# Commission rate applied to proposal final_price for revenue calculation (default: 2%)
COMMISSION_RATE=0.02

# --- CORS (Required in production) ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5000

# --- Redis / BullMQ (Optional — falls back to in-memory) ---
REDIS_URL=redis://localhost:6379

# --- Email / SMTP (Optional — falls back to console logging) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=

# --- Social Integrations (Optional) ---
FB_APP_SECRET=
FB_VERIFY_TOKEN=
ZALO_OA_SECRET=
ZALO_VERIFY_TOKEN=
