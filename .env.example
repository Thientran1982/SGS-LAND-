# ============================================================
# SGS LAND — Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ============================================================
# REQUIRED — server will not start without these in production
# ============================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/sgsland

# JWT signing secret — must be at least 64 random characters
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars

# Runtime environment (development | production)
NODE_ENV=development

# Port the server listens on (default: 5000)
PORT=5000

# ============================================================
# REQUIRED for specific features
# ============================================================

# --- AI features (chat, valuation, lead scoring) ---
GEMINI_API_KEY=
# Alternative: API_KEY=  (alias for GEMINI_API_KEY)

# --- Transactional email via Brevo (password reset, verification) ---
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@example.com
BREVO_FROM_NAME=SGS Land

# --- Email webhook authentication (choose one provider) ---
# Mailgun
EMAIL_MAILGUN_SIGNING_KEY=
# SendGrid
EMAIL_SENDGRID_WEBHOOK_KEY=
# Postmark
EMAIL_POSTMARK_WEBHOOK_TOKEN=
# Brevo
BREVO_WEBHOOK_SECRET=
# Generic token (any custom webhook caller)
EMAIL_WEBHOOK_TOKEN=

# ============================================================
# REQUIRED in production (recommended to set)
# ============================================================

# Comma-separated list of allowed CORS origins
# e.g. https://sgs-land.replit.app
ALLOWED_ORIGINS=http://localhost:5000

# Public-facing app URL (used in email links, webhooks)
APP_URL=http://localhost:5000
PUBLIC_URL=http://localhost:5000

# ============================================================
# OPTIONAL — falls back to safe defaults if not set
# ============================================================

# --- Redis / BullMQ (falls back to in-memory if not set) ---
# Required for multi-instance / production scale-out
REDIS_URL=redis://localhost:6379

# --- Logging level (error | warn | info | debug) ---
LOG_LEVEL=info

# --- Commission rate on proposal final_price (default: 2%) ---
COMMISSION_RATE=0.02

# --- Market data cache TTL in hours (default: 6) ---
MARKET_CACHE_TTL_HOURS=6

# --- SSO secret (required to enable enterprise SSO login) ---
SSO_SECRET=

# --- Seed password for demo/dev users (used by npm run seed) ---
SEED_PASSWORD=

# ============================================================
# OPTIONAL — Social / Webhook integrations
# ============================================================

# --- Facebook Messenger webhook ---
FB_APP_SECRET=
FB_VERIFY_TOKEN=

# --- Zalo OA webhook ---
ZALO_OA_SECRET=
ZALO_VERIFY_TOKEN=
ZALO_APP_ID=
